// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: messages
// Document ID: auto-generated
// Fields:
//   - authorName: string (required, 1-100 chars)
//   - content: string (required, 1-1000 chars)
//   - createdAt: timestamp (required)
//   - authorPhoto: string (optional, URL)
//   - authorUid: string (required, matches auth.uid)
//
// Collection: users
// Document ID: userId
// Fields:
//   - uid: string (required, matches auth.uid)
//   - displayName: string (required, 1-100 chars)
//   - photoURL: string (optional, URL)
//   - role: string (required, 'admin' or 'user')
//
// ===============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.authorUid;
    }

    function isValidMessage(data) {
      return data.authorName is string && data.authorName.size() >= 1 && data.authorName.size() <= 100 &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 1000 &&
             data.authorUid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 100 &&
             (data.role == 'user' || (data.role == 'admin' && isAdmin()));
    }

    function isAdmin() {
      return isAuthenticated() && 
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
              request.auth.token.email == "anshurawani25@gmail.com");
    }

    function isValidPhoto(data) {
      return data.url is string && isValidUrl(data.url) &&
             data.authorUid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /messages/{messageId} {
      allow read: if true; // Publicly readable for the birthday surprise
      allow create: if isAuthenticated() && isValidMessage(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidMessage(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /photos/{photoId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidPhoto(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidPhoto(request.resource.data);
      allow delete: if isAuthenticated() && (isDocOwner() || isAdmin());
    }

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
